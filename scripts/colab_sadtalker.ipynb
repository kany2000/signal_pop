    "for v in output_videos:\n",
    "    size = os.path.getsize(v) / 1024 / 1024\n",
    "    print(f'  {v} ({size:.1f}MB)')\n",
    "\n",
    "from google.colab import files\n",
    "for v in output_videos:\n",
    "    files.download(v)"
   ]
  }
