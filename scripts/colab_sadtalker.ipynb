    "## 4. 生成AI主播照片\n",
    "\n",
    "用Pollinations生成一张独特的主播照片。\n",
    "\n",
    "**性别设定：** 填入 `female`（女声Xiaoxiao）或 `male`（男声Yunyang）"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 设置主播性别\n",
    "GENDER = \"female\" # @param [\"female\", \"male\"]\n",
    "SEED = 42  # 改成不同数字得到不同面孔，比如 20260724"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests, urllib.parse, hashlib\n",
    "from PIL import Image\n",
    "from io import BytesIO\n",
    "\n",
    "# 根据性别生成不同prompt\n",
    "if GENDER == 'female':\n",
    "    prompt = ('professional Chinese female news anchor, head and shoulders portrait, '\n",
    "              'natural realistic body proportions, neutral studio background, '\n",
    "              'professional broadcast look, soft lighting, no text, no distortion')\n",
    "else:\n",
    "    prompt = ('professional Chinese male news anchor, head and shoulders portrait, '\n",
    "              'natural realistic body proportions, neutral studio background, '\n",
    "              'professional broadcast look, soft lighting, no text, no distortion')\n",
    "\n",
    "q = urllib.parse.quote(prompt)\n",
    "url = f'https://image.pollinations.ai/prompt/{q}?width=768&height=768&nologo=true&seed={SEED}'\n",
    "print(f'生成主播照片 seed={SEED}, gender={GENDER}...')\n",
    "resp = requests.get(url, headers={'User-Agent': 'Mozilla/5.0'}, timeout=120)\n",
    "img = Image.open(BytesIO(resp.content))\n",
    "face_path = 'anchor.jpg'\n",
    "img.save(face_path)\n",
    "print(f'✅ 生成完成: {face_path} ({img.size})')\n",
    "display(img)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. 上传TTS音频\n",
    "\n",
    "把Windows本地生成的 `tts.wav` 上传上来"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from google.colab import files\n",
    "uploaded_audio = files.upload()\n",
    "audio_path = list(uploaded_audio.keys())[0]\n",
